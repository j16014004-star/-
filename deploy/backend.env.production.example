# Copy to /opt/ai-career/backend/.env and replace every CHANGE_ME value.
APP_NAME=AI Career Agent
APP_ENV=production
DEBUG=False
AUTO_CREATE_TABLES=False
ENABLE_API_DOCS=False
ALLOWED_HOSTS=career.example.com
SECRET_KEY=CHANGE_ME_RANDOM_64_CHARACTERS

DB_HOST=rm-xxxxxxxx.mysql.rds.aliyuncs.com
DB_PORT=3306
DB_USER=ai_career_app
DB_PASSWORD=CHANGE_ME_DATABASE_PASSWORD
DB_NAME=ai_career_agent

JWT_SECRET_KEY=CHANGE_ME_DIFFERENT_RANDOM_64_CHARACTERS
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
TOTP_ENCRYPTION_KEY=CHANGE_ME_FERNET_COMPATIBLE_KEY_OR_LONG_RANDOM_SECRET

TENCENT_MAAS_API_KEY=CHANGE_ME_TENCENT_MAAS_API_KEY
TENCENT_MAAS_BASE_URL=https://tokenhub.tencentmaas.com/v1
TENCENT_MAAS_CHAT_MODELS=deepseek-v4-flash,glm-5.1,minimax-m2.7,minimax-m2.5,glm-5,kimi-k2.5
RESUME_OPTIMIZATION_MODEL=deepseek-v4-flash
CAREER_PLANNING_MODEL=deepseek-v4-flash
HR_ASSISTANT_MODEL=deepseek-v4-flash
MOCK_INTERVIEW_MODEL=deepseek-v4-flash
AI_REQUEST_TIMEOUT_SECONDS=120
AI_MAX_OUTPUT_TOKENS=8000
AI_MAX_RETRIES=1
AI_TEST_MODE=False

RESUME_OPTIMIZATION_KB_SOURCE_DIR=./knowledge_base/resume_optimization/source
RESUME_OPTIMIZATION_KB_PROCESSED_DIR=/opt/ai-career/data/knowledge/resume_optimization
CAREER_PLANNING_KB_SOURCE_DIR=./knowledge_base/career_planning/source
CAREER_PLANNING_KB_PROCESSED_DIR=/opt/ai-career/data/knowledge/career_planning
SKILL_ASSESSMENT_KB_SOURCE_DIR=./knowledge_base/skill_assessment/source
SKILL_ASSESSMENT_KB_PROCESSED_DIR=/opt/ai-career/data/knowledge/skill_assessment
JOB_RECOMMENDATION_KB_SOURCE_DIR=./knowledge_base/job_recommendation/source
JOB_RECOMMENDATION_KB_PROCESSED_DIR=/opt/ai-career/data/knowledge/job_recommendation
HR_COMMUNICATION_KB_SOURCE_DIR=./knowledge_base/hr_communication/source
HR_COMMUNICATION_KB_PROCESSED_DIR=/opt/ai-career/data/knowledge/hr_communication
INTERVIEW_PYTHON_KB_SOURCE_DIR=./knowledge_base/interview_python_backend/source
INTERVIEW_PYTHON_KB_PROCESSED_DIR=/opt/ai-career/data/knowledge/interview_python_backend
INTERVIEW_SECRETARY_KB_SOURCE_DIR=./knowledge_base/interview_secretary_studies/source
INTERVIEW_SECRETARY_KB_PROCESSED_DIR=/opt/ai-career/data/knowledge/interview_secretary_studies

QDRANT_ENABLED=True
QDRANT_LOCAL_MODE=True
QDRANT_LOCAL_PATH=/opt/ai-career/data/qdrant
LOCAL_KB_EMBEDDINGS=True
QDRANT_RESUME_COLLECTION=resume_optimization_kb
QDRANT_CAREER_COLLECTION=career_planning_kb
QDRANT_SKILL_ASSESSMENT_COLLECTION=career_skill_assessment_kb
QDRANT_JOB_RECOMMENDATION_COLLECTION=job_recommendation_kb
QDRANT_HR_COMMUNICATION_COLLECTION=hr_communication_kb
QDRANT_INTERVIEW_PYTHON_COLLECTION=interview_python_backend_kb
QDRANT_INTERVIEW_SECRETARY_COLLECTION=interview_secretary_studies_kb

UPLOAD_DIR=/opt/ai-career/data/uploads
PLATFORM_STATE_DIR=/opt/ai-career/data/storage_states
PLATFORM_STATE_ENCRYPTION_KEY=CHANGE_ME_RANDOM_64_CHARACTERS
OPERATIONS_ALERT_LOG=/opt/ai-career/data/logs/alerts/operations.jsonl
MAX_UPLOAD_SIZE_MB=10

CORS_ORIGINS=https://career.example.com
JOB_AUTO_REFRESH_ENABLED=True
HR_MONITOR_ENABLED=True
CRAWL_INTERVAL_HOURS=1
JOB_REFRESH_CHECK_MINUTES=15
HR_MONITOR_INTERVAL_SECONDS=30
PLAYWRIGHT_HEADLESS=True
PLAYWRIGHT_CRAWL_HEADLESS=True
PLATFORM_LOGIN_TIMEOUT_SECONDS=600

# For 58 manual login on a headless ECS, deploy a controlled Chromium/noVNC service
# and set both values. Leave empty only if third-party automation is disabled.
PLAYWRIGHT_CDP_ENDPOINT=
PLAYWRIGHT_REMOTE_VIEW_URL=

# Recommended for the first single-ECS deployment. Use celery only after Redis is ready.
WORKER_BACKEND=subprocess
WORKER_TASK_TIMEOUT_SECONDS=900
WORKER_TASK_MAX_RETRIES=2
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
