# Application
APP_NAME=AI Career Agent
APP_ENV=development
DEBUG=True
SECRET_KEY=change-me-in-production
API_PREFIX=/api/v1
AUTO_CREATE_TABLES=True
ENABLE_API_DOCS=True
ALLOWED_HOSTS=*

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=ai_career_agent

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# JWT
JWT_SECRET_KEY=change-me-in-production
TOTP_ENCRYPTION_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# OpenAI-compatible settings
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.7

# Tencent MaaS / AI Agent
TENCENT_MAAS_API_KEY=
TENCENT_MAAS_BASE_URL=https://tokenhub.tencentmaas.com/v1
TENCENT_MAAS_REGION=china-mainland
RESUME_OPTIMIZATION_MODEL=deepseek-v4-flash
CAREER_PLANNING_MODEL=deepseek-v4-flash
HR_ASSISTANT_MODEL=deepseek-v4-flash
HR_APPLICATION_MAX_OUTPUT_TOKENS=1200
HR_APPLICATION_PROMPT_VERSION=hr-application-v1
HR_REPLY_PROMPT_VERSION=hr-reply-v1
HR_INTERVIEW_PROMPT_VERSION=hr-interview-v1
TENCENT_MAAS_CHAT_MODELS=deepseek-v4-flash,glm-5.1,minimax-m2.7,minimax-m2.5,glm-5,kimi-k2.5
CAREER_QUESTION_MAX_OUTPUT_TOKENS=2000
CAREER_QUESTION_COOLDOWN_SECONDS=5
MOCK_INTERVIEW_MODEL=deepseek-v4-flash
MOCK_INTERVIEW_MAX_OUTPUT_TOKENS=4000
MOCK_INTERVIEW_PROMPT_VERSION=mock-interview-v1
TENCENT_MAAS_EMBEDDING_MODEL=kinfra-vl-embedding-2b
TENCENT_MAAS_EMBEDDING_DIMENSION=2048
TENCENT_MAAS_EMBEDDING_ENDPOINT=/embeddings/multimodal
AI_TEST_MODE=False
AI_TEST_MAX_LIVE_CALLS=10
AI_TEST_MAX_TOTAL_TOKENS=100000
AI_MAX_CONCURRENT_TASKS=1
AI_REQUEST_TIMEOUT_SECONDS=120
AI_MAX_RETRIES=0
AI_MAX_OUTPUT_TOKENS=8000
AI_THINKING_ENABLED=False
AI_TEMPERATURE=0.2
AI_RAG_TOP_K=2
AI_RAG_CHUNK_SIZE=800
AI_RAG_CHUNK_OVERLAP=100
AI_EMBEDDING_BATCH_SIZE=1
AI_MAX_RESUME_CHARS=12000
AI_PROMPT_VERSION=resume-opt-v4
RESUME_OPTIMIZATION_KB_SOURCE_DIR=./knowledge_base/resume_optimization/source
RESUME_OPTIMIZATION_KB_PROCESSED_DIR=./knowledge_base/resume_optimization/processed
CAREER_PLANNING_KB_SOURCE_DIR=./knowledge_base/career_planning/source
CAREER_PLANNING_KB_PROCESSED_DIR=./knowledge_base/career_planning/processed
INTERVIEW_PYTHON_KB_SOURCE_DIR=./knowledge_base/interview_python_backend/source
INTERVIEW_PYTHON_KB_PROCESSED_DIR=./knowledge_base/interview_python_backend/processed
INTERVIEW_SECRETARY_KB_SOURCE_DIR=./knowledge_base/interview_secretary_studies/source
INTERVIEW_SECRETARY_KB_PROCESSED_DIR=./knowledge_base/interview_secretary_studies/processed

# Qdrant
QDRANT_ENABLED=False
QDRANT_LOCAL_MODE=True
QDRANT_LOCAL_PATH=./vector_store/qdrant
QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=
QDRANT_RESUME_COLLECTION=resume_optimization_kb
QDRANT_CAREER_COLLECTION=career_planning_kb
QDRANT_SKILL_ASSESSMENT_COLLECTION=career_skill_assessment_kb
QDRANT_JOB_RECOMMENDATION_COLLECTION=job_recommendation_kb
QDRANT_HR_COMMUNICATION_COLLECTION=hr_communication_kb
QDRANT_INTERVIEW_PYTHON_COLLECTION=interview_python_backend_kb
QDRANT_INTERVIEW_SECRETARY_COLLECTION=interview_secretary_studies_kb
LOCAL_KB_EMBEDDINGS=True
JOB_RECOMMENDATION_KB_SOURCE_DIR=./knowledge_base/job_recommendation/source
JOB_RECOMMENDATION_KB_PROCESSED_DIR=./knowledge_base/job_recommendation/processed
HR_COMMUNICATION_KB_SOURCE_DIR=./knowledge_base/hr_communication/source
HR_COMMUNICATION_KB_PROCESSED_DIR=./knowledge_base/hr_communication/processed
SKILL_ASSESSMENT_KB_SOURCE_DIR=./knowledge_base/skill_assessment/source
SKILL_ASSESSMENT_KB_PROCESSED_DIR=./knowledge_base/skill_assessment/processed
AI_RAG_MIN_VECTOR_SCORE=0.25
AI_RAG_CANDIDATE_MULTIPLIER=3

# Vector database
VECTOR_DB_PATH=./vector_store
CHROMA_COLLECTION_NAME=career_knowledge

# Uploads
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10

# Email
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Crawlers
CRAWL_INTERVAL_HOURS=1
JOB_AUTO_REFRESH_ENABLED=true
HR_MONITOR_ENABLED=true
HR_MONITOR_INTERVAL_SECONDS=30
JOB_REFRESH_CHECK_MINUTES=15
CRAWL_DELAY_SECONDS=2.0
JOB_CRAWL_MAX_QUERIES=6
JOB_CRAWL_PAGE_TIMEOUT_SECONDS=20
JOB_CRAWL_ITEM_WAIT_SECONDS=5
JOB_CRAWL_EARLY_STOP_RATIO=0.75
PLAYWRIGHT_HEADLESS=False
PLAYWRIGHT_CRAWL_HEADLESS=True
PLATFORM_LOGIN_TIMEOUT_SECONDS=600
PLATFORM_STATE_DIR=./storage_states
PLATFORM_STATE_ENCRYPTION_KEY=
PLAYWRIGHT_CDP_ENDPOINT=
PLAYWRIGHT_REMOTE_VIEW_URL=
WORKER_BACKEND=subprocess
WORKER_TASK_TIMEOUT_SECONDS=900
WORKER_TASK_MAX_RETRIES=2
OPERATIONS_ALERT_LOG=./logs/alerts/operations.jsonl
